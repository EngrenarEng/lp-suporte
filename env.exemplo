# ═══════════════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — Learning Passport Suporte Bot
# ═══════════════════════════════════════════════════════════════════════
# ATENÇÃO: Este arquivo é um MODELO. Renomeie para ".env" e preencha
# com os seus dados reais. NUNCA compartilhe este arquivo publicamente.
# No Render, estas variáveis são configuradas no painel do serviço.
# ═══════════════════════════════════════════════════════════════════════

# ─── Porta do servidor (o Render define automaticamente) ─────────────
PORT=3000

# ─── Claude API (Anthropic) ──────────────────────────────────────────
# Obter em: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Z-API (WhatsApp) ────────────────────────────────────────────────
# Obter em: https://developer.z-api.io → Sua instância
ZAPI_INSTANCE_ID=SUA_INSTANCE_ID_AQUI
ZAPI_TOKEN=SEU_TOKEN_AQUI
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN_AQUI

# ─── Google Sheets ───────────────────────────────────────────────────
# ID da planilha: está na URL do Google Sheets
# Ex: https://docs.google.com/spreadsheets/d/ESTE_É_O_ID/edit
GOOGLE_SHEET_ID=ID_DA_SUA_PLANILHA_AQUI

# Credenciais da Service Account (JSON em uma linha)
# Obter em: Google Cloud Console → APIs → Credenciais → Conta de serviço
# Cole o conteúdo COMPLETO do arquivo JSON entre as aspas simples:
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
